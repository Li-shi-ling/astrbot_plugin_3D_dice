{
  "node_path": {
    "description": "Node.js executable path",
    "type": "string",
    "default": "node",
    "hint": "Used to launch the local dice renderer."
  },
  "default_width": {
    "description": "Default GIF width",
    "type": "int",
    "default": 480
  },
  "default_height": {
    "description": "Default GIF height",
    "type": "int",
    "default": 480
  },
  "default_fps": {
    "description": "Default animation FPS",
    "type": "int",
    "default": 20
  },
  "default_frames": {
    "description": "Default animation frame count",
    "type": "int",
    "default": 36
  },
  "default_theme": {
    "description": "Default visual theme",
    "type": "string",
    "default": "classic",
    "options": ["classic", "ember", "emerald", "midnight"]
  },
  "max_dice_count": {
    "description": "Maximum number of dice in one request",
    "type": "int",
    "default": 8
  },
  "timeout_ms": {
    "description": "Node renderer timeout in milliseconds",
    "type": "int",
    "default": 30000
  },
  "debug": {
    "description": "Keep debug logs and intermediate JSON when true",
    "type": "bool",
    "default": false
  }
}
