    "hint": "最大会被限制为 6"
  },
  "duration_ms": {
    "description": "GIF 动画时长，单位毫秒",
    "type": "int",
    "default": 2200
  },
  "fps": {
    "description": "GIF 帧率",
    "type": "int",
    "default": 12
  },
  "width": {
    "description": "GIF 宽度",
    "type": "int",
    "default": 480
  },
  "height": {
    "description": "GIF 高度",
    "type": "int",
    "default": 360
  },
  "seed": {
    "description": "可选默认随机种子，留空则每次随机",
    "type": "string",
    "default": ""
  },
  "die_color": {
    "description": "骰子颜色，十六进制 RGB",
    "type": "string",
    "default": "#d83a34"
  },
  "background_color": {
    "description": "背景颜色，十六进制 RGB",
    "type": "string",
    "default": "#f5f7fb"
  },
  "max_cache_files": {
